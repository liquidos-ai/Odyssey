// Odyssey config template (matches current JSON5 schema)
{
  agents: {
    list: [
      {
        id: "odyssey-orchestrator",
        description: "Default managed Odyssey agent",
        prompt: "You are Odyssey, a secure agent runtime that follows explicit permissions and tool policy.",
        tools: { allow: ["*"], deny: [] },
      },
    ],
  },
  tools: {
    output_policy: {
      max_string_bytes: 32000,
      max_array_len: 256,
      max_object_entries: 256,
      redact_keys: ["api_key", "token"],
      redact_values: ["sk-"],
      replacement: "[REDACTED]",
    },
  },
  permissions: {
    mode: "default",
    rules: [
      { action: "ask", tool: "Bash" },
      { action: "deny", command: ["rm", "-rf"] },
    ],
  },
  memory: {
    provider: "file",
    path: ".odyssey/memory",
    capture: {
      capture_messages: true,
      capture_tool_output: false,
      detect_secrets: true,
      secret_entropy_threshold: 3.7,
    },
    compaction: {
      enabled: false,
      max_messages: 40,
      summary_max_chars: 1500,
    },
    instruction_roots: ["."],
  },
  skills: {
    setting_sources: ["user", "project"],
    paths: [".odyssey/skills"],
    allow: ["*"],
    deny: [],
  },
  mcp: {
    enabled: false,
    servers: [
      {
        name: "filesystem",
        protocol: "stdio",
        command: "node",
        args: ["./mcp/filesystem-server.js"],
        cwd: ".",
        description: "Sandboxed filesystem MCP server",
        env: {},
        sandbox: {
          filesystem: {
            read: ["./mcp"],
            write: [],
            exec: [],
          },
          network: {
            mode: "disabled",
          },
          env: {
            inherit: ["PATH"],
            set: {},
          },
          limits: {
            wall_clock_seconds: 300,
            stdout_bytes: 65536,
            stderr_bytes: 65536,
          },
        },
      },
    ],
  },

  sandbox: {
    enabled: true,
    mode: "workspace_write",
    filesystem: {
      read: ["."],
      write: ["."],
      exec: [],
    },
    network: {
      mode: "disabled",
    },
    env: {
      inherit: ["PATH"],
      set: {},
    },
    limits: {
      cpu_seconds: 30,
      memory_bytes: 1073741824,
      nofile: 256,
      pids: 128,
      wall_clock_seconds: 60,
      stdout_bytes: 65536,
      stderr_bytes: 65536,
    },
  },
  sessions: {
    enabled: true,
    path: ".odyssey/sessions",
  },
}
